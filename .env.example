# ── Required: fal.ai ─────────────────────────────────────────────────────────
# API key from https://fal.ai/dashboard/keys. Pay-per-second; commercial use is permitted.
# One key serves BOTH render backends (Kling & Seedance) and the voice/upscale endpoints.
# Mint a persistent voice per character once:  npm run mint-voice -- <name> <clip.wav>
FAL_KEY=
# Default endpoint is reference-to-video: a text prompt + character `elements` (look + bound voice),
# no first frame required. Override only with another endpoint that has the same `elements` schema:
# FAL_KLING_ENDPOINT=fal-ai/kling-video/o3/standard/reference-to-video   # default (~720p, $0.112/s w/ audio); .../o3/pro/... = native 1080p at $0.14/s
# FAL_UPLOAD_MODE=data-uri    # data-uri (default, inline) | storage (fal CDN upload)
# Optional fal Topaz upscale (used when UPSCALE_ENABLED=true or `--upscale`):
# FAL_TOPAZ_ENDPOINT=fal-ai/topaz/upscale/video
# FAL_TOPAZ_MODEL=Proteus
# FAL_TOPAZ_MAX_FACTOR=4

# ── Web app (npm run web) ────────────────────────────────────────────────────
# WEB_PORT=5177                   # localhost port for the web app
# WEB_NO_OPEN=1                   # don't auto-open the browser when the web app starts
# KLING_SEGMENT_MAX_BYTES=500     # per-segment prompt budget in UTF-8 bytes (fal rejects 512 despite documenting it)
# VIDEO_SHORT_SIDE=1080           # stitch canvas scale — its SHAPE follows each run's aspect (16:9/9:16/1:1)
# VIDEO_WIDTH=1080                # explicit canvas override (set BOTH; ignores aspect — mostly for tests)
# VIDEO_HEIGHT=1920
# RUNS_DIR=./runs                 # where runs live; OUT_DIR / WORK_DIR / CACHE_DIR work the same.
#                                 # NOTE: these are generic names — if your shell exports them for
#                                 # something else, set them here explicitly to pin this project.

# ── Render backend ───────────────────────────────────────────────────────────
# Which video model renders your specs; or pass --backend on engine/render per run.
# RENDER_BACKEND=kling            # kling (default) | seedance
# Seedance 2.0 (ByteDance) — endpoint ids verbatim from fal.ai; note: NO `fal-ai/` prefix on these:
# FAL_SEEDANCE_ENDPOINT=bytedance/seedance-2.0/reference-to-video
# FAL_SEEDANCE_PROBE_ENDPOINT=bytedance/seedance-2.0/reference-to-video   # --probe endpoint (standard tier at SEEDANCE_PROBE_RESOLUTION; mini/fast drift characters)
# SEEDANCE_RESOLUTION=480p        # 480p | 720p | 1080p | 4k — price scales with resolution: 480p ≈ $0.14/s, 1080p ≈ $0.68/s (2x Kling). Default 480p + Topaz upscale on approve = 1080p master for less (docs/COST.md)
# SEEDANCE_PROBE_RESOLUTION=480p
# SEEDANCE_GENERATE_AUDIO=true    # native lip-synced audio
# SEEDANCE_STYLE=                 # optional global style directive prepended to every Seedance prompt
# SEEDANCE_AVOID=                 # optional appearance guard (Seedance has no negative_prompt — guards ride the prompt)
# SEEDANCE_TEXT_RULE=             # optional replacement for the default "no on-screen text" rule
# SEEDANCE_UPLOAD_MODE=storage    # storage (default: stable CDN URLs) | data-uri

# ── Engine LLM (pick ONE provider) ──────────────────────────────────────────
# provider: claude | openai | gemini | copilot     transport: api | cli
#   claude / openai / gemini  -> api (default) or cli
#   copilot (GitHub Copilot CLI) -> cli ONLY (set LLM_TRANSPORT=cli)
LLM_PROVIDER=claude
LLM_TRANSPORT=cli
# Set the model id for your provider, e.g.:
#   claude   -> claude-opus-4-8
#   openai   -> a GPT/Codex model id
#   gemini   -> a Gemini model id
#   copilot  -> a Copilot model id (e.g. claude-sonnet-4.5, gpt-5); leave blank for its default
LLM_MODEL=claude-opus-4-8
# Provide the key for your chosen provider (optional if LLM_TRANSPORT=cli and you're logged in):
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# copilot auth is GitHub's — run `copilot` once to log in, or set GITHUB_TOKEN:
# GITHUB_TOKEN=
# Or set a single generic key (takes precedence for api providers):
# LLM_API_KEY=
# transport=cli only: binary to spawn (claude | codex | gemini | copilot). Empty = provider default.
# LLM_CLI_BIN=
# transport=cli only: extra args appended to the CLI (escape hatch for flag quirks), space-separated.
# LLM_CLI_ARGS=
# Optional: run the CLI on a remote host over SSH.
# LLM_SSH_HOST=
# LLM_SSH_USER=
# LLM_SSH_KEY=

# ── Character voices (transport=fal) ────────────────────────────────────────
# With KLING_GENERATE_AUDIO=true, Kling speaks each VO line natively. On the fal transport it uses the
# speaking character's persistent minted voice_id — mint one per character once (stored in ./voices):
#   npm run mint-voice -- <name> <clip.wav>
# VOICES_DIR=./voices

# ── Optional overrides (see config.js for the full list & defaults) ─────────
# KLING_MODEL=kling-v3-omni
# KLING_RESOLUTION=1080p
# KLING_ASPECT=9:16
# KLING_MULTI_SHOT=true
# KLING_GENERATE_AUDIO=true
# KLING_CHAIN_FRAMES=true   # >15s renders seed each job with the previous clip's last frame (seam continuity)
# UPSCALE_ENABLED=false
